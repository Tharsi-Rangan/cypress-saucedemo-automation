  },
  "homepage": "https://github.com/Tharsi-Rangan/cypress-saucedemo-automation#readme",
  "devDependencies": {
    "cypress": "^15.11.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
