{
  "name": "cypress-saucedemo-automation",
  "version": "1.0.0",
  "description": "SEPQM Cypress Automation Testing Assignment using SauceDemo",
  "main": "index.js",
  "scripts": {
  "cy:open": "cypress open",
  "cy:run": "cypress run",
  "report:run": "cypress run",
  "report:merge": "npx mochawesome-merge cypress/reports/mocha/*.json -o cypress/reports/report.json",
  "report:generate": "npx marge cypress/reports/report.json -f report -o cypress/reports/html",
  "test:report": "npm run report:run && npm run report:merge && npm run report:generate"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tharsi-Rangan/cypress-saucedemo-automation.git"
  },
